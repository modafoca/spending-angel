{
  "manifest_version": 3,
  "name": "Spending Angel — Sensor",
  "version": "0.3.0",
  "description": "The eyes for the Spending Angel app: detects checkout intent and signals the app. Renders nothing on its own.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Spending Angel — Sensor"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["domains.js", "log.js", "detect.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
