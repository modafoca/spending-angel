{
  "manifest_version": 3,
  "name": "Spending Angel",
  "version": "0.1.0",
  "description": "The angel on your shoulder when you're about to spend. Reminds you what you're saving for.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Spending Angel"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["domains.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sounds/*.mp3", "icons/*.svg", "icons/*.png", "onboarding.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
